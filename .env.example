# Qara Clinic Twenty app environment example.
# Do not commit real secrets. Keep production values in Render and in the
# Twenty workspace application server variables.

# Twenty app sync/deploy target. The URL can be the Render web service URL.
TWENTY_DEPLOY_URL=https://<render-twenty-service>.onrender.com
TWENTY_DEPLOY_API_KEY=

# Integration/smoke tests against a running Twenty server.
TWENTY_API_URL=https://<render-twenty-service>.onrender.com
TWENTY_API_KEY=

# OpenRouter / AI.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=https://<render-twenty-service>.onrender.com
OPENROUTER_APP_NAME=qara-clinic
DEFAULT_MODEL_PATIENT=minimax/minimax-m3
DEFAULT_MODEL_PATIENT_FALLBACK=z-ai/glm-5.2
DEFAULT_MODEL_INTERNAL=deepseek/deepseek-chat
DEFAULT_MODEL_INTERNAL_FALLBACK=z-ai/glm-5.2
AI_TIMEOUT_MS=30000
AI_LOG_FULL_PROMPTS=false

# Meta Cloud API / WhatsApp.
META_ACCESS_TOKEN=
META_PHONE_NUMBER_ID=
META_VERIFY_TOKEN=
META_APP_SECRET=
META_GRAPH_BASE_URL=https://graph.facebook.com/v20.0

# Twenty server infrastructure variables for the Render web service.
# These are not application serverVariables, but the hosted Twenty server needs
# equivalents configured in its own environment.
APP_SECRET=
DATABASE_URL=
REDIS_URL=
