NODE_ENV=development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/qara-crm
PORT=4000
CORS_ORIGIN=http://localhost:3000
CORS_DOMAIN=http://localhost:3000
JWT_SECRET=change-me-in-production-min-32-chars
SESSION_EXPIRY_HOURS=24
LOG_LEVEL=info
ADMIN_PASSWORD=change-me-before-seeding-production

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=http://localhost:3000
OPENROUTER_APP_NAME=qara-clinic
DEFAULT_MODEL_PATIENT=minimax/minimax-m3
DEFAULT_MODEL_PATIENT_FALLBACK=z-ai/glm-5.2
DEFAULT_MODEL_INTERNAL=deepseek/deepseek-v4-flash
DEFAULT_MODEL_INTERNAL_FALLBACK=deepseek/deepseek-chat
AI_TIMEOUT_MS=30000
AI_MAX_OUTPUT_TOKENS=600
AI_MAX_INPUT_CHARS=12000
AI_MAX_CONTEXT_MESSAGES=20
AI_MAX_CONTEXT_CHARS=10000

META_ACCESS_TOKEN=
META_PHONE_NUMBER_ID=
META_VERIFY_TOKEN=qara-verify-token
META_APP_SECRET=
META_GRAPH_BASE_URL=https://graph.facebook.com/v20.0
# Instagram Direct (envio de respostas): token de acesso da Página vinculada ao IG
INSTAGRAM_PAGE_ACCESS_TOKEN=
# ID usado no path do envio (/{ID}/messages); vazio usa "me" (a própria Página)
INSTAGRAM_SEND_ID=
WHATSAPP_FOLLOWUP_TEMPLATE=qara_followup_24h
# Fase 6: envia o lembrete D-1 (qara_appointment_reminder_d1) com botões
# quick-reply (Confirmar / Remarcar) via Meta Cloud API, permitindo ao paciente
# confirmar/remarcar num toque sem passar pela IA. Só ligar depois que os
# botões do template estiverem aprovados no Business Manager — a Meta rejeita
# o envio se o template aprovado não tiver os botões. Default false: envia o
# template sem botões (comportamento atual).
APPOINTMENT_CONFIRM_BUTTONS=false
TAWANY_PROMPT_VERSION=v1
TAWANY_DEBOUNCE_MS=20000
ENABLE_SCHEDULER=false
SHADOW_MODE=shadow
# Follow-up engine (setInterval no server): default 900000 (15 min); 0 desliga
FOLLOWUP_INTERVAL_MS=900000
# Follow-up de orçamentos: dias sem resposta (status SENT) até gerar a task de
# cobrança + HSM qara_budget_followup. Default 3.
BUDGET_FOLLOWUP_DAYS=3
TWENTY_FORWARD_URL=

LEAD_WEBHOOK_SECRET=change-me-before-enabling-external-lead-webhook

# LEVA 2B: pesquisa NPS pós-consulta via WhatsApp. No dia seguinte a uma
# consulta concluída, envia o template HSM perguntando a nota (0 a 10); a
# captura da resposta é determinística (sem IA, ver
# logic-functions/nps-capture.ts). Default false: só ligar depois que o
# template estiver aprovado no Business Manager.
NPS_ENABLED=false
# Nome do template aprovado na Meta, se for diferente de qara_nps_pos_consulta
# (constante HSM_NPS_TEMPLATE em lib/templates/hsm-messages.ts).
NPS_TEMPLATE=
# Janela (em horas) em que uma resposta numérica após o envio do template
# ainda é capturada como nota NPS. Fora dela, a mensagem segue o fluxo normal
# (bots/Tawany) em vez de ser tratada como resposta à pesquisa. Default 48.
NPS_CAPTURE_WINDOW_HOURS=48

# Knowledge vivo da Tawany: no deploy, após `prisma migrate deploy`, rodar UMA vez
# `pnpm db:seed:knowledge` (idempotente: só insere se a tabela KnowledgeSection
# estiver vazia). Sem seed, a Tawany usa o prompt hardcoded como fallback.
