{
  "name": "@qara/api",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "NODE_PATH=dist node dist/src/server.js",
    "lint": "oxlint src",
    "test": "vitest run",
    "test:integration": "DATABASE_URL=postgresql://localhost:5432/qara-crm-test JWT_SECRET=test-secret-key-at-least-32-bytes-long META_VERIFY_TOKEN=test-meta-token META_APP_SECRET=test-app-secret-32-bytes-long ENABLE_SCHEDULER=false TAWANY_DEBOUNCE_MS=0 SHADOW_MODE=human_approval vitest run --config vitest.integration.config.ts",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "tsx src/lib/seed/seed.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "@qara/shared": "workspace:*",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "express-rate-limit": "^8.5.2",
    "jsonwebtoken": "^9.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.0",
    "@types/cors": "^2.8.0",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^24.0.0",
    "@types/supertest": "^7.2.0",
    "oxlint": "^1.72.0",
    "prisma": "^6.0.0",
    "supertest": "^7.2.2",
    "tsx": "^4.0.0",
    "typescript": "^5.9.0",
    "vitest": "^3.0.0"
  }
}
